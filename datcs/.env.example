# Map providers
VITE_MAP_PROVIDER=tilemap
VITE_TILEMAP_KEY=

# Desktop release download URLs
VITE_DACTS_DOWNLOAD_WINDOWS=
VITE_DACTS_DOWNLOAD_MACOS=
VITE_DACTS_DOWNLOAD_LINUX=

# Backend
DACTS_BACKEND_HOST=0.0.0.0
DACTS_BACKEND_PORT=4300
DACTS_CORS_ORIGIN=http://localhost:5173

# Placeholder future integrations
WEATHER_API_BASE_URL=
VIETNAM_LEGAL_ZONE_FEED_URL=
