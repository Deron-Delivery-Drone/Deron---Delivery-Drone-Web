{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DATCS",
  "version": "0.1.0",
  "identifier": "com.deron.datcs",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DATCS — Deron Air Traffic Control Station",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["desktop-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
